# .env.example — copia a .env y ajusta. El .env NO se commitea.
#
# El modulo de Compras NO necesita secretos para funcionar (los datos son
# JSON locales). Estas variables son opcionales / para despliegue.

# Puerto local del servidor de desarrollo (por defecto 5060).
ROLS_ERP_PORT=5060

# Carpeta de datos de runtime en produccion (persiste FUERA del docroot para
# que deploy/git no la toquen). En local se ignora y se usa shared/data/.
# ROLS_DATA_DIR=/var/www/vhosts/rolscarpets.com/rols-erp-produccion-data

# Marca de app compuesta bajo un dominio (sub-rutas). Solo en el compositor de
# Rols One; aqui NO se pone (la app corre suelta en su propio dominio/puerto).
# ROLS_COMPOSED=1

# === API v1 (la consume el escandallo de Rols One) ===
# Token compartido que protege /api/v1/*. PREFERIR esta variable de entorno a
# dejar el fichero erp_api_token.txt dentro del repo. Debe ser EL MISMO valor en
# este ERP y en Rols One. Genera uno fuerte en el servidor:
#   openssl rand -hex 32
# ROLS_ERP_API_TOKEN=pon_aqui_un_secreto_largo
# Si no se define, el token se lee de ROLS_DATA_DIR/erp_api_token.txt.

# === Enlaces al ecosistema Rols One (IdP + home) ===
# El login (rols-cuentas) y el home viven en Rols One, en otro subdominio. Por
# defecto se deducen del host (local -> puertos; prod -> one.rolscarpets.com).
# Solo hace falta ponerlos si cambia el dominio de Rols One.
# ROLS_ONE_BASE=https://one.rolscarpets.com
# ROLS_CUENTAS_BASE=https://one.rolscarpets.com/cuentas
