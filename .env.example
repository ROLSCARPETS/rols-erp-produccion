# .env.example — copia a .env y ajusta. El .env NO se commitea.
#
# El modulo de Compras NO necesita secretos para funcionar (los datos son
# JSON locales). Estas variables son opcionales / para despliegue.

# Puerto local del servidor de desarrollo (por defecto 5060).
ROLS_ERP_PORT=5060

# Carpeta de datos de runtime en produccion (persiste FUERA del docroot para
# que deploy/git no la toquen). En local se ignora y se usa shared/data/.
# ROLS_DATA_DIR=/var/www/vhosts/rolscarpets.com/rols-erp-produccion-data

# Marca de app compuesta bajo un dominio (sub-rutas). Solo en el compositor de
# Rols One; aqui NO se pone (la app corre suelta en su propio dominio/puerto).
# ROLS_COMPOSED=1
